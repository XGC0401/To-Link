{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Launch Backend",
            "request": "launch",
            "mainClass": "com.feature.neighbourHood_backend.Application",
            "projectName": "neighbourHood-backend",
            "cwd": "${workspaceFolder}/neighbourHood-backend",
            "env": {
                "SPRING_DATASOURCE_URL": "${env:SPRING_DATASOURCE_URL}",
                "SPRING_DATASOURCE_USERNAME": "${env:SPRING_DATASOURCE_USERNAME}",
                "SPRING_DATASOURCE_PASSWORD": "${env:SPRING_DATASOURCE_PASSWORD}",
                "SUPABASE_ENDPOINT": "${env:SUPABASE_ENDPOINT}",
                "SUPABASE_ACCESS_KEY": "${env:SUPABASE_ACCESS_KEY}",
                "SUPABASE_SECRET_KEY": "${env:SUPABASE_SECRET_KEY}",
                "SUPABASE_BUCKET": "${env:SUPABASE_BUCKET}"
            }
        }
    ]
}